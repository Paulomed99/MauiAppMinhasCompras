<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAppMinhasCompras.Views.NovoProduto"
             Title="Novo Produto">

    <ContentPage.ToolbarItems>
        <ToolbarItem x:Name="btn_salvar" Text="Salvar" Clicked="ToolbarItem_Clicked"/>
    </ContentPage.ToolbarItems>

    <Grid>

    
        <VerticalStackLayout Spacing="10" Padding="10">
        
            <Label Text="Descrição do produto:"/>
            <Entry x:Name="txt_descricao"/>
        
            <Label Text="Quantidade:"/>
            <Entry x:Name="txt_quantidade" Keyboard="Numeric"/>
        
            <Label Text="Preço unitário:"/>
            <Entry x:Name="txt_preco" Keyboard="Numeric"/>

            <Label Text="Selecione a categoria"/>
            <Picker x:Name="pck_categoria" Title="Selecione..." ItemsSource="{Binding ListaCategorias}" />

            <Label Text="Data de compra"/>
            <DatePicker x:Name="dt_dataCompra" Format="dd/MM/yyyy"/>

        </VerticalStackLayout>

        <Grid x:Name="grid_carregamento" BackgroundColor="#80000000" IsVisible="False">

            <ActivityIndicator x:Name="carregador" 
                               IsRunning="False" 
                               Color="White" 
                               HorizontalOptions="Center" 
                               VerticalOptions="Center" 
                               WidthRequest="60" 
                               HeightRequest="60" />

            <Label Text="Salvando..." 
                   TextColor="White" 
                   HorizontalOptions="Center" 
                   VerticalOptions="Center" 
                   Margin="0,90,0,0" />
        </Grid>


    </Grid>
    
    
    
</ContentPage>